{
  "libraryId": "caui",
  "displayName": "CAUI Component Library",
  "aarDependency": {
    "group": "com.incall.apps",
    "artifact": "caui",
    "version": "3.0.9.3.2-SNAPSHOT"
  },
  "defaultPackage": "com.incall.apps.caui.widget",
  "styleableFilter": {
    "mode": "class_index",
    "excludePrefixes": ["android", "AppCompat", "Material", "androidx"],
    "excludeSuffixes": ["Style", "Adapter", "Theme"]
  },
  "textStylePatterns": [
    "^(CAUITextStyle[A-Za-z0-9]+?)([RB])?$",
    "^(CAUI\\.TextAppearance\\.[A-Za-z0-9_.]+?)$"
  ],
  "textStylePrefixes": ["CAUITextStyle", "CAUI.TextAppearance"],
  "preferredTextAttrs": ["cauiTextStyle", "android:textAppearance"],
  "preferredColorAttrs": ["android:textColor"],
  "rulesFile": "widget_semantic_rules.json",
  "snapshotFile": "widget_registry.snapshot.json"
}
